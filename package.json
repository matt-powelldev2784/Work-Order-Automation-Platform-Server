{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "******************************************************A": "echo DEV ENV SCRIPTS",
    "dev": "dotenv -e .env.test -- tsx watch src/index.ts",
    "dev:prod": "dotenv -e .env.prod -- tsx watch src/index.ts",
    "worker:dev": "dotenv -e .env.test -- tsx watch src/worker.ts",
    "******************************************************B": "echo PRODUCTION ENV SCRIPTS",
    "start": "node dist/index.js",
    "worker:start": "node dist/worker.js",
    "build": "tsc -p tsconfig.json",
    "******************************************************C": "echo PRISMA SCRIPTS",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "prisma:studio": "prisma studio",
    "prisma:migrate:dev": "dotenv -e .env.test -- prisma migrate dev",
    "prisma:deploy:test": "dotenv -e .env.test -- prisma migrate deploy",
    "prisma:deploy:prod": "dotenv -e .env.prod -- prisma migrate deploy",
    "******************************************************D": "echo PRETTIER SCRIPTS",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
