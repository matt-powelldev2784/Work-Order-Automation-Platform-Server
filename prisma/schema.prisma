generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobSheetStatus {
  pending
  processing
  ready
  failed
}

enum JobStatus {
  new
  assigned
  in_progress
  completed
}

model Job {
  id                  Int            @id @default(autoincrement())
  customerName        String
  jobAddress          String
  jobType             String
  description         String
  jobSheetStatus      JobSheetStatus @default(pending) @map("job_sheet_status")
  jobStatus           JobStatus      @default(new) @map("job_status")
  fileUrl             String?
  createdAt           DateTime       @default(now())
  completedAt         DateTime?
  assignedFieldUserId String?        @db.Uuid @map("field_user_id")
  notesFromField      String?
  createdByUserId     String?        @db.Uuid @map("created_by_user_id")
  updatedAt           DateTime       @updatedAt

  @@map("jobs")
}
